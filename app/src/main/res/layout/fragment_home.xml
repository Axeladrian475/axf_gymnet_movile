<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── Header con saludo y botón logout ─────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBienvenida"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Hola, Usuario!"
                    android:textColor="@color/white"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-black"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bienvenido de regreso"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnLogout"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_logout"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="Cerrar sesión"
                android:padding="8dp"/>

        </LinearLayout>

        <!-- ── Estadísticas: Puntos y Racha ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <!-- Puntos -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆"
                        android:textSize="22sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvPuntos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/orange_primary"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-black"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="puntos"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Racha -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="22sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvRacha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 días"
                        android:textColor="@color/orange_primary"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-black"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="racha activa"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ── Título sección suscripción ────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MI MEMBRESÍA"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="10dp"/>

        <!-- ── Shimmer mientras carga ────────────────────────────────────── -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerSuscripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:visibility="gone">

            <include layout="@layout/item_shimmer_card"/>

        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- ── Card suscripción activa ───────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSuscripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Row: indicador + tipo + estado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:id="@+id/indicatorEstado"
                        android:layout_width="4dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_indicator_rounded"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTipoSuscripcion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Membresía Mensual"
                            android:textColor="@color/white"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-black"/>

                        <TextView
                            android:id="@+id/tvFechaVencimiento"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vence: 30 May 2026"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEstadoSuscripcion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Activa"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="@color/success"/>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp"/>

                <!-- Sesiones restantes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Sesiones entrenador -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvSesionesEntrenador"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/orange_primary"
                            android:textSize="26sp"
                            android:fontFamily="sans-serif-black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💪 sesiones entreno"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:gravity="center"/>

                    </LinearLayout>

                    <!-- Separador vertical -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider"
                        android:layout_marginHorizontal="8dp"/>

                    <!-- Sesiones nutriólogo -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvSesionesNutriologo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/orange_primary"
                            android:textSize="26sp"
                            android:fontFamily="sans-serif-black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🥗 sesiones nutrición"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp"
                            android:gravity="center"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Card sin suscripción ──────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSinSuscripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="36sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin membresía activa"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acércate al staff del gimnasio\npara renovar tu membresía"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
