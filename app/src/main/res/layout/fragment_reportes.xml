<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark"
        app:elevation="0dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPORTES"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incidencias en el gimnasio"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Tabs: Públicos / Mis Reportes -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/bg_dark"
            app:tabSelectedTextColor="@color/orange_primary"
            app:tabTextColor="@color/text_muted"
            app:tabIndicatorColor="@color/orange_primary"
            app:tabIndicatorHeight="3dp"
            app:tabRippleColor="@color/orange_primary"
            app:tabPaddingStart="20dp"
            app:tabPaddingEnd="20dp"
            app:tabGravity="fill"
            app:tabMode="fixed">
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activos"/>
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mis Reportes"/>
        </com.google.android.material.tabs.TabLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Shimmer loading -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerReportes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp">

                <include layout="@layout/item_shimmer_card"/>
                <include layout="@layout/item_shimmer_card"/>
                <include layout="@layout/item_shimmer_card"/>

            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_report"
                android:alpha="0.25"/>

            <TextView
                android:id="@+id/tvEmptyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No hay reportes"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvEmptySubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sé el primero en reportar\nuna incidencia"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Lista principal -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReportes"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false"/>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <!-- FAB Nuevo Reporte -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabNuevoReporte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="Reportar"
        android:textColor="@color/bg_dark"
        android:fontFamily="sans-serif-medium"
        app:icon="@drawable/ic_add"
        app:iconTint="@color/bg_dark"
        app:backgroundTint="@color/orange_primary"
        app:elevation="6dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
